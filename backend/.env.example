# ============================================================
# Backend Environment Variables — Copy to .env and fill in
# ============================================================

# Django Core
SECRET_KEY=change-me-to-a-long-random-string-50-chars
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com

# CORS — your Amplify frontend URL(s)
CORS_ALLOWED_ORIGINS=https://yourdomain.amplifyapp.com,https://www.yourdomain.com

# ─── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgres://outfit_user:strongpassword@localhost:5432/outfit_stylist_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ─── AWS S3 ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_STORAGE_BUCKET_NAME=outfit-stylist-bucket
AWS_S3_REGION_NAME=us-east-1

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ─── Email (Gmail App Password) ──────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── AI Models ───────────────────────────────────────────────
YOLO_MODEL_PATH=/home/ubuntu/outfit-app/ai_models/yolo/weights/yolov8n-fashion.pt
CLIP_MODEL_NAME=patrickjohncyh/fashion-clip
VTON_MODEL_PATH=/home/ubuntu/outfit-app/ai_models/vton/weights/

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
